name: Deploy Config Server

on:
  push:
    branches: ["main"]
  pull_request:
    branches: ["main"]
  workflow_dispatch:
    inputs:
      image_tag:
        description: "Tag de imagen Docker (opcional). Ej: 1.2.3"
        required: false
        type: string
      environment:
        description: "Ambiente de despliegue"
        required: true
        default: "prd"
        type: choice
        options:
          - dev
          - stg
          - prd
      instance:
        description: "Instancia de despliegue"
        required: true
        default: "1"
        type: choice
        options:
          - "1"
          - "2"
          - "3"

jobs:
  build-and-push:
    runs-on: ubuntu-latest

    outputs:
      image_tag: ${{ steps.compute.outputs.NEW_VERSION }}

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Git Semantic Version
        id: version
        uses: PaulHatch/semantic-version@v4.0.3
        with:
          major_pattern: "major:"
          minor_pattern: "feat:"
          format: "${major}.${minor}.${patch}-prerelease"

      - name: Compute image tag
        id: compute
        run: |
          if [ "${{ github.event_name }}" = "workflow_dispatch" ] && [ -n "${{ inputs.image_tag }}" ]; then
            echo "NEW_VERSION=${{ inputs.image_tag }}" >> "$GITHUB_ENV"
            echo "NEW_VERSION=${{ inputs.image_tag }}" >> "$GITHUB_OUTPUT"
          else
            echo "NEW_VERSION=${{ steps.version.outputs.version }}" >> "$GITHUB_ENV"
            echo "NEW_VERSION=${{ steps.version.outputs.version }}" >> "$GITHUB_OUTPUT"
          fi

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Cache Docker layers
        uses: actions/cache@v4
        with:
          path: /tmp/.buildx-cache
          key: ${{ runner.os }}-docker-${{ hashFiles('**/Dockerfile') }}
          restore-keys: |
            ${{ runner.os }}-docker-

      - name: Docker login (Docker Hub)
        env:
          DOCKER_USER: ${{ secrets.DOCKER_USERNAME }}
          DOCKER_PASSWORD: ${{ secrets.DOCKER_PASSWORD }}
        run: echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USER" --password-stdin

      - name: Build & Push amd64
        run: |
          docker buildx build \
            --platform linux/amd64 \
            --cache-from type=local,src=/tmp/.buildx-cache \
            --cache-to type=local,dest=/tmp/.buildx-cache \
            -t alberth1414/config-server:${NEW_VERSION} \
            -t alberth1414/config-server:latest \
            --push .

  update-ops:
    needs: build-and-push
    runs-on: ubuntu-latest

    env:
      DEPLOY_ENV: ${{ inputs.environment || 'prd' }}
      DEPLOY_INSTANCE: ${{ inputs.instance || '1' }}
      IMAGE_TAG: ${{ needs.build-and-push.outputs.image_tag }}
      OPS_REPO: Garilab/config-platform-configserver-spring-ops
      PATCH_PATH: apps/config-platform-configserver-spring/overlays

    steps:
      - name: Checkout OPS repository
        uses: actions/checkout@v4
        with:
          repository: ${{ env.OPS_REPO }}
          token: ${{ secrets.OPS_REPO_TOKEN }}
          ref: main

      - name: Update image in patch-deployment.yaml
        run: |
          TARGET_FILE="${PATCH_PATH}/${DEPLOY_ENV}/instances/${DEPLOY_INSTANCE}/patch-deployment.yaml"

          echo "============================================"
          echo "Ambiente:  ${DEPLOY_ENV}"
          echo "Instancia: ${DEPLOY_INSTANCE}"
          echo "Archivo:   ${TARGET_FILE}"
          echo "Nueva imagen: alberth1414/config-server:${IMAGE_TAG}"
          echo "============================================"

          if [ ! -f "$TARGET_FILE" ]; then
            echo "ERROR: No se encontro el archivo ${TARGET_FILE}"
            exit 1
          fi

          # Reemplaza la linea de image: con la nueva imagen y tag
          sed -i "s|image:.*alberth1414/config-server:.*|image: alberth1414/config-server:${IMAGE_TAG}|g" "$TARGET_FILE"

          echo "Contenido actualizado:"
          cat "$TARGET_FILE"

      - name: Commit and push changes
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"

          git add -A
          if git diff --cached --quiet; then
            echo "No hay cambios para commitear."
          else
            git commit -m "chore(${DEPLOY_ENV}): update config-server image to ${IMAGE_TAG} [instance ${DEPLOY_INSTANCE}]"
            git push origin main
          fi
